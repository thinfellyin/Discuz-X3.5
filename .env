# Docker Compose project name. Used as container name prefix.
COMPOSE_PROJECT_NAME=discuz35

# Web access port: http://127.0.0.1:18080/
APP_PORT=18080

# Optional host port for directly connecting to MySQL from host tools.
MYSQL_HOST_PORT=33060

# Time zone.
TZ=Asia/Shanghai

# MySQL settings used by the Discuz installer.
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=discuz
MYSQL_USER=discuz
MYSQL_PASSWORD=change_me_discuz_password
